# ==============================================================
# Jornada Test Framework — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ==============================================================

# Ambiente ativo: dev | staging | prod
ENV=dev

# Credenciais OAuth 2.0
OAUTH_CLIENT_ID=your-client-id-here
OAUTH_CLIENT_SECRET=your-client-secret-here
OAUTH_TOKEN_URL=https://auth.itau.com.br/oauth/token
OAUTH_SCOPE=jornada:read jornada:write

# URLs base por ambiente (sobrescritas pelo config YAML, mas podem vir do env)
API_BASE_URL_DEV=http://localhost:8080
API_BASE_URL_STAGING=https://api-staging.jornada-futuro.itau.com.br
API_BASE_URL_PROD=https://api.jornada-futuro.itau.com.br

# Timeouts (segundos)
REQUEST_TIMEOUT=30
TOKEN_REFRESH_MARGIN=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
